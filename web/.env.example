# Copy this file to .env and fill in the values from your Firebase project settings
# (Firebase Console -> Project Settings -> General -> Your apps -> SDK setup and configuration).
# .env is git-ignored on purpose: these values are specific to your own Firebase project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Optional: automatic failure-notification emails (free) ---
# Without these, failed tests still offer a one-tap "Email Failure Report" button that
# opens the evaluator's own mail app prefilled. To make sending fully automatic, create a
# free account at https://www.emailjs.com (free tier: 200 emails/month, no credit card):
#   1. Add an Email Service (e.g. connect a Gmail account) -> copy its Service ID.
#   2. Create an Email Template with:
#        To Email:  {{to_email}}
#        Subject:   {{subject}}
#        Content:   {{message}}
#      -> copy its Template ID.
#   3. Account page -> copy your Public Key.
# Then fill these in and redeploy (npm run deploy):
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
