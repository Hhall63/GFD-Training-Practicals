rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isActiveAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.isActive == true;
    }

    // Recruit profile photos.
    match /recruits/{recruitId}/{fileName} {
      allow read, write: if isActiveAdmin();
    }

    // Photo evidence attached to a failed (or optionally passed) test step.
    match /attachments/{sessionId}/{lineResultId}/{fileName} {
      allow read, write: if isActiveAdmin();
    }
  }
}
