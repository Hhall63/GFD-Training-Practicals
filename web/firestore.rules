rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    // Any signed-in, active account of any role (Administrator, Evaluator, or Recruit).
    function isActiveUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && myUserDoc().isActive == true;
    }

    // Accounts created before roles existed have no `role` field — treated as "admin" so
    // nobody's access silently changed when roles were introduced.
    function myRole() {
      return !('role' in myUserDoc()) ? 'admin' : myUserDoc().role;
    }

    // Staff = Administrators + Evaluators: the people who run tests on recruits.
    function isStaff() {
      return isActiveUser() && (myRole() == 'admin' || myRole() == 'evaluator');
    }

    function isAdminRole() {
      return isActiveUser() && myRole() == 'admin';
    }

    function isRecruitRole() {
      return isActiveUser() && myRole() == 'recruit';
    }

    // Anonymous Firebase Auth session used only by the public, no-login Live Dashboard
    // (/live/:token). Rules can't see the URL/token — that check happens in
    // LiveDashboardPage.jsx itself by reading the publicLiveLinks doc below. This function
    // only proves "this request is an anonymous session", which is why read access granted
    // to it below is a deliberate, documented widening (see the design spec) rather than a
    // real per-link access boundary.
    function isAnonymousLiveViewer() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // There's no server here, so the very first admin account has to bootstrap itself the
    // first time the app is ever opened. Once meta/appState.firstAdminCreated is true, this
    // door closes and every account after that must be created by an existing administrator.
    function noAdminExistsYet() {
      return !exists(/databases/$(database)/documents/meta/appState)
        || get(/databases/$(database)/documents/meta/appState).data.firstAdminCreated != true;
    }

    match /meta/appState {
      allow get: if true;
      allow create, update: if noAdminExistsYet() || isAdminRole();
    }

    match /admins/{adminId} {
      // `get` for any signed-in user (needed for the role checks above and to load one's
      // own account). `list` for staff: evaluators need to query the notify-on-failure
      // admin list when a recruit fails a test. Recruits cannot browse accounts.
      // Anonymous Live Dashboard sessions are explicitly excluded — they have no app
      // account and no legitimate reason to read any admin's profile, even their own.
      allow get: if isSignedIn() && !isAnonymousLiveViewer();
      allow list: if isStaff();
      // The bootstrap self-create path (claiming the first admin slot) is also excluded for
      // anonymous sessions — not exploitable today since this app already has admins, but the
      // same class of gap as the `get` exclusion above: a future state with zero admin docs
      // (fresh install, disaster recovery) must not let an anonymous visitor seize it.
      allow create: if isAdminRole() || (request.auth.uid == adminId && noAdminExistsYet() && !isAnonymousLiveViewer());
      allow update: if isAdminRole()
        || (isSignedIn()
            && request.auth.uid == adminId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mustChangePassword'])
            && request.resource.data.mustChangePassword == false);
      allow delete: if isAdminRole();
    }

    match /publicLiveLinks/{token} {
      // The token itself is the secret — never listed by an anonymous viewer, only fetched
      // by exact id (LiveDashboardPage does a single getDoc, never a query). Admins can list
      // to find "the current active link" for the Reports-home control.
      allow get: if true;
      allow list: if isAdminRole();
      allow write: if isAdminRole();
    }

    match /recruits/{recruitId} {
      // Staff read the roster to pick who they're testing; a Recruit may read only their
      // own linked record. Only administrators write. Anonymous Live Dashboard sessions can
      // also get/list (read-only) — the command board's readiness matrix needs recruit names,
      // per the deliberate exposure tradeoff documented on isAnonymousLiveViewer() above.
      allow get: if isStaff() || (isRecruitRole() && myUserDoc().recruitId == recruitId) || isAnonymousLiveViewer();
      allow list: if isStaff() || isAnonymousLiveViewer();
      allow write: if isAdminRole() || (isStaff() && recruitId == 'practice-recruit');
    }

    match /templates/{templateId} {
      // Drafts are visible to administrators only. Published tests are visible to
      // everyone active (evaluators run them; recruits see them on their status list).
      // Templates created before the draft feature have no `status` field — treated as
      // published, since they were already live. Anonymous Live Dashboard sessions can also
      // read (any status) — the command board's readiness matrix needs template names,
      // per the deliberate exposure tradeoff documented on isAnonymousLiveViewer() above.
      allow read: if isAdminRole()
        || (isActiveUser() && (!('status' in resource.data) || resource.data.status == 'published'))
        || isAnonymousLiveViewer();
      allow write: if isAdminRole();

      match /lines/{lineId} {
        // Line-level reads don't re-check the parent's draft status (rules can't cheaply
        // join): staff-only is fine because only staff run tests. Recruits never need
        // individual lines — their view is session results, not template content.
        allow read: if isStaff();
        allow write: if isAdminRole();
      }
    }

    match /testGroups/{groupId} {
      // Bundles of existing templates for running several back-to-back on one recruit
      // (e.g. "PPE Practicals" bundling 4 existing tests). Staff read the list to start a
      // group test from Home; only administrators build/manage groups.
      allow get: if isStaff();
      allow list: if isStaff();
      allow write: if isAdminRole();
    }

    match /sessions/{sessionId} {
      // Staff run tests and record results. A Recruit may read only their own sessions.
      // Anonymous Live Dashboard sessions can also read session summaries (result, recruit,
      // template) for the command board — but never lineResults below, which stay
      // staff-only (evaluator notes, photo URLs are not part of the deliberate exposure).
      allow read: if isStaff() || (isRecruitRole() && resource.data.recruitId == myUserDoc().recruitId) || isAnonymousLiveViewer();
      allow write: if isStaff();

      match /lineResults/{lineResultId} {
        allow read, write: if isStaff();
      }
    }
  }
}
